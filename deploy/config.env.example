# OZ Relay — Server Configuration
# Copy to /opt/oz-relay/config/config.env and fill in values.
# FIX #12: This file must be chmod 600 and owned by oz-relay.

# Server bind address
# With Caddy (production): 127.0.0.1:3400 (Caddy handles external TLS)
# Without Caddy (IP-only): 0.0.0.0:3400 (direct access)
RELAY_BIND_ADDR=0.0.0.0:3400

# Public URL (what developers see)
# Update to https://relay.ozapi.net when DNS + Caddy are configured
RELAY_URL=http://157.157.52.90:3400

# JWT signing secret for bsk_ tokens (generate with: openssl rand -hex 32)
RELAY_JWT_SECRET=CHANGE_ME_TO_RANDOM_64_HEX_CHARS

# Ed25519 signing key path
RELAY_SIGNING_KEY=/opt/oz-relay/keys/signing.pkcs8

# Source repo path (bare git clone)
RELAY_SOURCE_REPO=/opt/arcflow/repo.git

# Worktree directory for sandbox sessions
RELAY_WORKTREE_DIR=/opt/arcflow/.relay-worktrees

# Promotions queue directory
RELAY_PROMOTIONS_DIR=/opt/promotions

# Claude Code / Anthropic API
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME

# Sandbox timeout (seconds)
RELAY_SANDBOX_TIMEOUT=1800

# nsjail config path
RELAY_NSJAIL_CONFIG=/opt/oz-relay/config/nsjail.cfg

# GPU: make CUDA available inside sandbox (for cargo test with GPU features)
RELAY_ENABLE_GPU=true
